// Prezidox Academy — Prisma Schema
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── STUDENT ACCOUNT ───────────────────────────────
model User {
  id               String        @id @default(cuid())
  firstName        String
  lastName         String
  email            String        @unique
  passwordHash     String
  emailVerified    Boolean       @default(false)
  verifyToken      String?
  resetToken       String?
  resetTokenExpiry DateTime?
  role             String        @default("student")
  examFocus        String        @default("unilag")
  selectedSubjects String[]      @default([])
  trialStartedAt   DateTime?
  trialExpiresAt   DateTime?
  points           Int           @default(0)
  streak           Int           @default(0)
  lastActiveDate   DateTime?
  suspended        Boolean       @default(false)

  // ── v2 fields ──
  profileComplete    Boolean   @default(false)
  examLeaveActive    Boolean   @default(false)
  examLeaveEarnedAt  DateTime?
  battlePoints       Int       @default(0)
  battleRank         String    @default("Recruit")
  studyHallId        String?
  studyHallName      String    @default("Preparatory")

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  subscription     Subscription?
  sessions         ExamSession[]
  leaderboard      LeaderboardEntry[]
  pointAdjustments PointAdjustment[]
}

// ─── SUBSCRIPTION / PAYMENT ─────────────────────────
model Subscription {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan        String    // "unilag", "oau", "bundle"
  status      String    // "active", "expired", "manual"
  paystackRef String?
  amountPaid  Int?      // in kobo (multiply naira by 100)
  paidAt      DateTime?
  expiresAt   DateTime?
  note        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── EXAM QUESTION ───────────────────────────────────
model Question {
  id          String   @id @default(cuid())
  category    String   // "unilag", "oau", "jamb", "waec", "neco", "jupeb", "undergrad"
  subject     String
  topic       String
  year        Int?
  question    String
  optionA     String
  optionB     String
  optionC     String
  optionD     String
  answer      String   // "A", "B", "C", or "D"
  explanation String?
  glossary    Json?    // { "term": "definition" }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── EXAM SESSION ────────────────────────────────────
model ExamSession {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode           String   // "study-topic", "mastery", "cbt", "custom"
  category       String
  subject        String?
  topic          String?
  score          Int      // 0-100 percentage
  totalQuestions Int
  correctAnswers Int
  timeTaken      Int      // seconds
  answers        Json     // { questionId: { selected: "A", correct: "B", isCorrect: true } }
  completedAt    DateTime @default(now())
}

// ─── LEADERBOARD ─────────────────────────────────────
model LeaderboardEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  period    String   // "weekly", "monthly", "alltime"
  points    Int      @default(0)
  rank      Int?
  weekKey   String?  // e.g. "2026-W22"
  monthKey  String?  // e.g. "2026-05"
  updatedAt DateTime @updatedAt

  @@unique([userId, period, weekKey, monthKey])
}

// ─── BLOG POST ───────────────────────────────────────
model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String
  content     String
  category    String    // "jamb", "waec", "post-utme", "study-tips", "news"
  coverImage  String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── ADMIN ACCOUNT ───────────────────────────────────
model Admin {
  id                 String    @id @default(cuid())
  name               String
  email              String    @unique
  passwordHash       String
  role               String    @default("admin") // "admin" or "superadmin"
  mustChangePassword Boolean   @default(true)
  lastLoginAt        DateTime?
  failedLoginCount   Int       @default(0)
  lockedUntil        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  auditLogs        AuditLog[]
  pointAdjustments PointAdjustment[]
}

// ─── POINTS ADJUSTMENT LOG ──────────────────────────
model PointAdjustment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id])
  amount    Int      // can be negative
  reason    String
  createdAt DateTime @default(now())
}

// ─── ADMIN AUDIT LOG ─────────────────────────────────
model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id])
  action    String   // e.g. "SUSPEND_USER", "DELETE_QUESTION", "RESET_LEADERBOARD"
  target    String   // e.g. "user:abc123"
  detail    Json?
  createdAt DateTime @default(now())
}

// ─── PLATFORM SETTINGS ───────────────────────────────
model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

// ════════════════════════════════════════════════════
// v2 MODELS
// ════════════════════════════════════════════════════

// ─── ACADEMIC POINTS LOG ─────────────────────────────
model AcademicPoints {
  id        String   @id @default(cuid())
  userId    String
  source    String
  points    Int
  sessionId String?
  weekKey   String
  monthKey  String
  createdAt DateTime @default(now())
}

// ─── ACADEMIC RANK ───────────────────────────────────
model AcademicRank {
  id          String   @id @default(cuid())
  userId      String   @unique
  totalPoints Int      @default(0)
  weekPoints  Int      @default(0)
  monthPoints Int      @default(0)
  rank        String   @default("Freshman")
  weekRank    Int?
  monthRank   Int?
  allTimeRank Int?
  updatedAt   DateTime @updatedAt
}

// ─── SEASON POINTS ───────────────────────────────────
model SeasonPoints {
  id       String  @id @default(cuid())
  userId   String
  weekKey  String
  points   Int     @default(0)
  hallId   String?
  position Int?
  @@unique([userId, weekKey])
}

// ─── STUDY HALL ──────────────────────────────────────
model StudyHall {
  id        String   @id @default(cuid())
  name      String
  level     Int
  weekKey   String
  createdAt DateTime @default(now())
}

// ─── STUDY HALL STANDING ─────────────────────────────
model StudyHallStanding {
  id        String  @id @default(cuid())
  userId    String
  hallId    String
  weekKey   String
  points    Int     @default(0)
  position  Int?
  promoted  Boolean @default(false)
  relegated Boolean @default(false)
  @@unique([userId, weekKey])
}

// ─── BATTLE POINTS LOG ───────────────────────────────
model BattlePoints {
  id        String   @id @default(cuid())
  userId    String
  source    String
  points    Int
  battleId  String?
  weekKey   String
  monthKey  String
  createdAt DateTime @default(now())
}

// ─── BATTLE RANK ─────────────────────────────────────
model BattleRank {
  id                String   @id @default(cuid())
  userId            String   @unique
  totalBattlePoints Int      @default(0)
  rank              String   @default("Recruit")
  wins              Int      @default(0)
  losses            Int      @default(0)
  draws             Int      @default(0)
  winRate           Float    @default(0)
  currentWinStreak  Int      @default(0)
  bestWinStreak     Int      @default(0)
  updatedAt         DateTime @updatedAt
}

// ─── BATTLE ──────────────────────────────────────────
model Battle {
  id              String    @id @default(cuid())
  code            String    @unique
  challengerId    String
  opponentId      String?
  isAI            Boolean   @default(false)
  aiLevel         String?
  subject         String
  questionCount   Int
  questions       Json
  status          String    @default("pending")
  challengerScore Int?
  opponentScore   Int?
  winnerId        String?
  expiresAt       DateTime
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  isGhost             Boolean   @default(false)
  ghostScore          Int?
  ghostCorrectAnswers Int?
  ghostAnswerTimes    Json?
  isDraw              Boolean   @default(false)
}

// ─── BATTLE ANSWER ───────────────────────────────────
model BattleAnswer {
  id         String   @id @default(cuid())
  battleId   String
  userId     String
  questionId String
  answer     String
  isCorrect  Boolean
  timeTaken  Int
  answeredAt DateTime @default(now())
}

// ─── TOPIC MASTERY ───────────────────────────────────
model TopicMastery {
  id        String   @id @default(cuid())
  userId    String
  subject   String
  topic     String
  level     String   @default("Not Started")
  bestScore Int      @default(0)
  attempts  Int      @default(0)
  updatedAt DateTime @updatedAt
  @@unique([userId, subject, topic])
}

// ─── YEAR VAULT COMPLETION ───────────────────────────
model YearVaultCompletion {
  id           String   @id @default(cuid())
  userId       String
  category     String
  year         Int
  score        Int
  passedCutoff Boolean
  completedAt  DateTime @default(now())
  @@unique([userId, category, year])
}

// ─── SPEED STATS ─────────────────────────────────────
model SpeedStats {
  id            String   @id @default(cuid())
  userId        String
  score         Int
  accuracy      Float
  avgTimePerQ   Float
  fastestAnswer Float
  slowestAnswer Float
  bestStreak    Int
  completedAt   DateTime @default(now())
}

// ─── TOURNAMENT ──────────────────────────────────────
model Tournament {
  id        String   @id @default(cuid())
  weekKey   String
  division  String
  bracket   Json
  status    String   @default("active")
  winnerId  String?
  createdAt DateTime @default(now())
}

// ─── SUBJECT MASTERY ─────────────────────────────────
model SubjectMastery {
  id        String   @id @default(cuid())
  userId    String
  subject   String
  level     String   @default("Unranked")
  updatedAt DateTime @updatedAt
  @@unique([userId, subject])
}

// ─── STREAK RECORD ───────────────────────────────────
model StreakRecord {
  id                String    @id @default(cuid())
  userId            String    @unique
  currentStreak     Int       @default(0)
  bestStreak        Int       @default(0)
  examLeaveActive   Boolean   @default(false)
  examLeaveEarnedAt DateTime?
  lastStudyDate     DateTime?
  updatedAt         DateTime  @updatedAt
}

// ─── NOTIFICATION ────────────────────────────────────
model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  ctaText   String?
  ctaUrl    String?
  channel   String
  read      Boolean   @default(false)
  readAt    DateTime?
  sentAt    DateTime  @default(now())
  createdAt DateTime  @default(now())
}

// ─── ADMIN BROADCAST ─────────────────────────────────
model AdminBroadcast {
  id             String    @id @default(cuid())
  adminId        String
  type           String
  title          String
  body           String
  targetAudience String
  recipientCount Int       @default(0)
  channels       String
  scheduledAt    DateTime?
  sentAt         DateTime?
  status         String    @default("draft")
  createdAt      DateTime  @default(now())
}
